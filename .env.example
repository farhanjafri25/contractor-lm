# App
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/clm?retryWrites=true&w=majority

# Redis / BullMQ
# Upstash: copy the "Redis URL" from your Upstash console (starts with rediss://)
REDIS_URL=rediss://default:<your-upstash-password>@<your-upstash-host>.upstash.io:6380

# Local dev only (ignored when REDIS_URL is set)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# JWT
JWT_SECRET=changeme_use_a_long_random_string
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=changeme_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (AES-256 for auth tokens stored in tenant_applications)
ENCRYPTION_KEY=32_char_hex_key_here

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@clm.io

# Frontend URL (for invite links)
FRONTEND_URL=http://localhost:3001
